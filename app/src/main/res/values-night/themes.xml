<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night application theme -->
    <style name="Theme.GrowDaily" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/high_light_dark</item>
        <item name="colorPrimaryVariant">@color/high_light_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/brand_blue</item>
        <item name="colorSecondaryVariant">@color/brand_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/high_light_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
