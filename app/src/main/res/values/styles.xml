<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="mainColorText">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/main_text_color</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAppearance">?attr/textAppearanceSubtitle1</item>
    </style>

    <style name="CategoryColorCircle" >
        <item name="android:layout_width">27dp</item>
        <item name="android:layout_height">27dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:background">@drawable/circular</item>
        <item name="android:contentDescription">@string/none</item>
        <item name="android:tint">@color/white</item>
    </style>

    <style name="CategoryStrokeCircle">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:background">@drawable/stroke_circular_dark</item>
    </style>

    <style name="TaskBottomSheetDialogTheme"
        parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="bottomSheetStyle">@style/TaskBottomSheetStyle</item>
    </style>


    <style name="TaskBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@drawable/circular_corners_more</item>
    </style>

    <style name="WeekLabelText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">9dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">#8A8A8A</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:layout_marginBottom">1dp</item>
    </style>





</resources>