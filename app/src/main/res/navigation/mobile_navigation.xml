<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/nav_main">

    <fragment
        android:id="@+id/nav_diary"
        android:name="com.anitech.scoremyday.fragment.DiaryFragment"
        android:label="@string/menu_diary"
        tools:layout="@layout/fragment_diary" />

    <fragment
        android:id="@+id/nav_main"
        android:name="com.anitech.scoremyday.fragment.MainFragment"
        tools:layout="@layout/fragment_main" />


    <fragment
        android:id="@+id/nav_home"
        android:name="com.anitech.scoremyday.fragment.HomeFragment"
        android:label="@string/menu_home"
        tools:layout="@layout/fragment_home">

    </fragment>

    <fragment
        android:id="@+id/nav_add_task"
        android:name="com.anitech.scoremyday.fragment.AddTaskFragment"
        android:label="@string/menu_add_task"
        tools:layout="@layout/fragment_add_task">

        <argument
            android:name="task"
            app:argType="com.anitech.scoremyday.data_class.DailyTask"
            app:nullable="true"
            android:defaultValue="@null"
            />
    </fragment>

    <fragment
        android:id="@+id/nav_add_diary"
        android:name="com.anitech.scoremyday.fragment.AddDiaryFragment"
        android:label="@string/menu_add_diary"
        tools:layout="@layout/fragment_add_diary"
        >
        <argument
            android:name="diary"
            app:argType="com.anitech.scoremyday.data_class.DiaryEntry"
            app:nullable="true"
            android:defaultValue="@null"
            />

        <argument
            android:name="date"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/imageProviderFragment"
        android:name="com.anitech.scoremyday.fragment.ImageProviderFragment"
        android:label="Select Logo"
        tools:layout="@layout/fragment_image_provider" />

    <fragment
        android:id="@+id/manageCondition"
        android:name="com.anitech.scoremyday.fragment.ManageConditionFragment"
        android:label="Manage Condition"
        tools:layout="@layout/fragment_manage_condition" />

</navigation>
