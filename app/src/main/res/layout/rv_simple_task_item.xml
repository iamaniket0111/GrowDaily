<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"

    >

    <LinearLayout
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/task_fragment_card"
        android:gravity="center_vertical"

        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:minHeight="74dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginVertical="16dp">

            <ImageView
                android:id="@+id/imageProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circular"
                android:contentDescription="@string/none"
                android:padding="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_bell"
                app:tint="@color/white" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/taskType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Daily"
                android:textColor="@color/brand_blue"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/taskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:minLines="1"
                android:text="Start the Day"
                android:textColor="@color/task_text_primary"
                android:textSize="16sp" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/doneContainer"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/circular2"
            android:backgroundTint="@color/task_done_track">

            <ImageView
                android:id="@+id/done"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/circular"
                android:backgroundTint="@color/task_card_surface"
                android:src="@drawable/ic_check"
                app:tint="@color/white" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
