<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/task_screen_bg"
    android:paddingHorizontal="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/circular"
        android:backgroundTint="@color/task_card_stroke" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/task_fragment_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/organize_task_title"
                android:textColor="@color/task_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEmptyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/organize_task_hint"
                android:textColor="@color/task_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtSelectionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/circular_corners"
            android:backgroundTint="@color/brand_blue"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/task_fragment_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lists_header"
            android:textColor="@color/task_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCreateChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/task_filter_chip"
            android:backgroundTint="@color/task_filter_selected_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="@string/add_new_list"
            android:textColor="@color/brand_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLists"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/txtEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/task_fragment_card"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/no_lists_empty_state"
            android:textColor="@color/task_text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/createListContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/task_fragment_card"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/etListName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/list_name_hint"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:paddingHorizontal="6dp"
            android:textColor="@color/task_text_primary"
            android:textColorHint="@color/task_text_secondary" />

        <TextView
            android:id="@+id/btnCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/circular_corners"
            android:backgroundTint="@color/brand_blue"
            android:gravity="center"
            android:text="@string/create_button"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp" />

        <TextView
            android:id="@+id/btnCloseCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/task_filter_chip"
            android:backgroundTint="@color/task_done_track"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="@string/cancel_button"
            android:textColor="@color/task_text_secondary"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/brand_blue"
        android:text="@string/apply_lists"
        android:textColor="@android:color/white"
        android:paddingVertical="12dp"
        android:textSize="16sp"
        android:textAllCaps="false" />

</LinearLayout>
