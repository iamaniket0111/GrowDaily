<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/circular_corners"
    android:orientation="vertical"
    android:padding="16dp">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:letterSpacing="0.05"
        android:text="HISTORY"
        android:textColor="@color/black"
        android:textStyle="normal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/scrollToStartDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/circular_corners"
            android:backgroundTint="@color/lightBackground"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp">

            <ImageView
                android:id="@+id/btnPrevYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Previous year"
                android:paddingEnd="2dp"
                android:src="@drawable/ic_left_arrow"
                app:tint="@color/brand_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="start day"
                android:textColor="#9E9E9E" />


        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/scrollToCurrentDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/circular_corners"
            android:backgroundTint="@color/lightBackground"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="current day"
                android:textColor="#9E9E9E" />

            <ImageView
                android:id="@+id/btnNextYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Next year"
                android:paddingStart="2dp"
                android:src="@drawable/ic_right_arrow"
                app:tint="@color/brand_blue" />
        </LinearLayout>


    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/week_expanded_rv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>