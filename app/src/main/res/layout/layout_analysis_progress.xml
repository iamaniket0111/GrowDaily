<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/task_fragment_card"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <!-- Section Title -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PROGRESS"
        android:textStyle="normal"
        android:layout_marginBottom="12dp"
        android:textColor="@color/task_text_primary"
        android:letterSpacing="0.05"
    />


    <!-- Segmented Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/analysis_segment_container_bg"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/tabWeek"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/circular_corners"
            android:gravity="center"
            android:text="Week"
            android:textColor="@color/task_text_primary"
            android:textSize="14sp"
         />



        <TextView
            android:id="@+id/tabMonth"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Month"
            android:textColor="@color/task_text_secondary"
            android:textSize="14sp" />


        <TextView
            android:id="@+id/tabYear"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Year"
            android:textColor="@color/task_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Period Selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnPrevious"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="Previous"
            android:background="@drawable/circular"
            android:backgroundTint="@color/task_chip_surface"
            android:src="@drawable/ic_left_arrow"
            app:tint="@color/brand_blue" />

        <TextView
            android:id="@+id/txtCurrentPeriod"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="March 2026"
            android:textColor="@color/task_text_primary"
            android:textSize="16sp"
            android:letterSpacing="-0.02"
            android:textFontWeight="@integer/material_motion_duration_medium_1"/>



        <ImageView
            android:id="@+id/btnNext"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="Next"
            android:background="@drawable/circular"
            android:backgroundTint="@color/task_chip_surface"
            android:src="@drawable/ic_right_arrow"
            app:tint="@color/brand_blue" />
    </LinearLayout>

    <!-- Bar Chart Placeholder -->
    <include
        android:id="@+id/barGraph2"
        layout="@layout/bar_graph_layout" />

</LinearLayout>
