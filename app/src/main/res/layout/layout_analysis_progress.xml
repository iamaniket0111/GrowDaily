<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutProgressSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/circular_corners"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <!-- Section Title -->
    <TextView
        android:id="@+id/txtProgressTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Progress"
        android:textColor="?android:textColorPrimary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Segmented Tabs -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/circular_corners"
        android:backgroundTint="@color/light_gray_25"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/tabWeek"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/circular_corners"
            android:gravity="center"
            android:text="Week"
            android:textColor="?android:textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabMonth"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Month"
            android:textColor="#777777"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tabYear"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Year"
            android:textColor="#777777"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Period Selector -->
    <LinearLayout
        android:id="@+id/layoutPeriodSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnPrevious"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="Previous"
            android:padding="6dp"
            android:src="@drawable/ic_left_arrow"
            app:tint="@color/brand_blue" />

        <TextView
            android:id="@+id/txtCurrentPeriod"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="March 2026"
            android:textColor="?android:textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="Next"
            android:padding="6dp"
            android:src="@drawable/ic_right_arrow"
            app:tint="@color/brand_blue" />
    </LinearLayout>

    <!-- Bar Chart Placeholder -->
    <include
        android:id="@+id/barGraph2"
        layout="@layout/bar_graph_layout" />

</LinearLayout>
