<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_surface_card"
    android:orientation="vertical"
    android:paddingHorizontal="22dp"
    android:paddingTop="22dp"
    android:paddingBottom="18dp">

    <View
        android:id="@+id/viewAccent"
        android:layout_width="38dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/completion_dialog_chip_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="22dp"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp"
            android:elevation="2dp">

            <View
                android:id="@+id/previewBackground"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/circular"
               />

            <ImageView
                android:id="@+id/imagePreview"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_trophy"
                android:alpha="0.9"
                app:tint="@color/white"
                />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Choose Icon &amp; Color"
            android:textColor="@color/dialog_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Background Color"
        android:textSize="14sp"
        android:textColor="@color/dialog_text_secondary"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:weightSum="8"
        android:layout_marginBottom="20dp"
        android:padding="6dp"
        android:background="@drawable/completion_dialog_section_bg">

        <FrameLayout
            android:id="@+id/frame1"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_red"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                android:visibility="gone"
                app:tint="@color/white" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame2"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_orange"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame3"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_yellow"
                android:contentDescription="@string/none" />

            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame4"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_green"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame5"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_teal"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame6"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_blue"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame7"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_purple"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame8"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/brand_blue"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                 app:tint="@color/white"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/task_card_stroke"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Icons"
        android:textSize="14sp"
        android:textColor="@color/dialog_text_secondary"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/symbolRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/completion_dialog_section_bg"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/completion_dialog_button_secondary"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="@color/completion_dialog_button_secondary_text"
            android:textSize="15sp"
            android:textStyle="bold"
            />

        <Button
            android:id="@+id/doneBtn"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/brand_blue"
            android:text="Done"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            />
    </LinearLayout>

</LinearLayout>
