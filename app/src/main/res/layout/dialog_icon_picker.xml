<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/circular_corners"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header with Preview - Improved spacing and alignment -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <!-- Preview Circle - Slightly larger for better visibility -->
        <FrameLayout
            android:id="@+id/previewContainer"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp"
            android:elevation="2dp">

            <View
                android:id="@+id/previewBackground"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/circular"
                android:backgroundTint="@color/brand_blue" />

            <ImageView
                android:id="@+id/imagePreview"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_trophy"
                android:alpha="0.9"
                app:tint="@color/white"
                />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Choose Icon &amp; Color"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#202124" />
    </LinearLayout>

    <!-- Color Selection - Improved grid layout -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Background Color"
        android:textSize="14sp"
        android:textColor="#5F6368"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:weightSum="8"
        android:layout_marginBottom="20dp"
        android:padding="4dp"
        android:backgroundTint="#F8F9FA"
        android:background="@drawable/circular_corners"
        >

        <FrameLayout
            android:id="@+id/frame1"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_red"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame2"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_orange"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame3"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_yellow"
                android:contentDescription="@string/none" />

            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame4"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_green"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame5"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_teal"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame6"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_blue"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame7"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/category_purple"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/frame8"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                style="@style/CategoryColorCircle"
                android:backgroundTint="@color/brand_blue"
                android:contentDescription="@string/none" />
            <View style="@style/CategoryStrokeCircle" />
        </FrameLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="20dp" />

    <!-- Icon Selection -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Icons"
        android:textSize="14sp"
        android:textColor="#5F6368"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/symbolRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#F8F9FA"
        android:background="@drawable/circular_corners"
        android:padding="8dp" />

    <!-- Action Buttons - Material Design style -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/cancelBtn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="CANCEL"
            android:textColor="#757575"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/doneBtn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="DONE"
            android:textColor="#2196F3"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

</LinearLayout>