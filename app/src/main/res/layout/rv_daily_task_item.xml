<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/body"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/circular_corners"
    android:backgroundTint="@color/white"
    android:baselineAligned="false"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="6dp">

    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginVertical="16dp">

        <ImageView
            android:id="@+id/imageProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circular"
            android:contentDescription="@string/none"
            android:padding="6dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_bell"
            app:tint="@color/white" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/taskTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:minLines="1"
                android:text="Start the Day"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/taskWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/4" />
        </LinearLayout>

        <TextView
            android:id="@+id/taskNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="5"
            android:text="be ready for the day"

            />
    </LinearLayout>

    <ImageButton
        android:id="@+id/specificNoteBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/none"
        android:src="@drawable/ic_pencil"
        app:tint="@color/category_dark_blue"
        android:background="@drawable/circular"
        android:backgroundTint="@color/white"
        android:padding="6dp"
        android:focusable="true"
        android:clickable="true"
        android:visibility="gone"
        />

    <FrameLayout
        android:id="@+id/doneContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/circular2"
        android:backgroundTint="@color/black"
        android:padding="8dp">

        <ImageView
            android:id="@+id/done"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_check"
            app:tint="#8BC34A" />
    </FrameLayout>

</LinearLayout>