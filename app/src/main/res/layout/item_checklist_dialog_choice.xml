<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/add_form_surface_card"
    android:backgroundTint="@color/completion_dialog_row_surface"
    android:gravity="center_vertical"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="10dp">

    <CheckBox
        android:id="@+id/checkChecklistChoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/brand_blue" />

    <TextView
        android:id="@+id/tvChecklistChoice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:textColor="@color/dialog_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
