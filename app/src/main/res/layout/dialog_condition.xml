<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/circular_corners_more"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exclude"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_gravity="center"
        android:drawablePadding="8dp"
        android:paddingBottom="12dp"
        app:drawableStartCompat="@drawable/ic_condition_check"
        android:drawableTint="@color/category_dark_blue"
        />

    <TextView
        android:id="@+id/dialogMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Tap to work on the conditions below. Tasks irrelevant to these conditions won’t affect your day score."
        android:textAlignment="center"
        android:textColor="#8A8A8A"
        android:layout_marginTop="15dp"
        android:textSize="14sp" />
    <!-- Options -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/RvCondition"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        />

    <Button
        android:id="@+id/btn_done"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/category_dark_blue"
        android:text="close"
        android:layout_marginTop="20dp"
        android:textColor="@android:color/white" />
</LinearLayout>
