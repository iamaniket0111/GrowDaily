<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutTotalCompletion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/circular_corners"
    android:padding="20dp">

    <!-- Section Title -->
    <TextView
        android:id="@+id/txtTotalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COMPLETION RATE"
        android:textSize="12sp"
        android:textStyle="normal"
        android:textColor="@color/black"
        android:letterSpacing="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Percentage with Label -->
    <!-- Semi Circle Progress -->
    <FrameLayout
        android:id="@+id/layoutSemiCircle"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtTotalTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.anitech.growdaily.SemiCircleProgressView
            android:id="@+id/progressOverall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Percentage text centered at bottom of arc -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txtMainPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="78"
                android:textColor="@color/brand_blue"
                android:textSize="48sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/txtMainPercentageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textColor="@color/brand_blue"
                android:textSize="24sp"
                android:layout_marginStart="2dp"
                android:alpha="0.7"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Stats Row - Simplified -->
    <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/layoutSemiCircle">

        <!-- Achieved -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTotalAchieved"
                android:text="42"
                android:textColor="#2E7D32"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Achieved"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#E0E0E0"/>

        <!-- Missed -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTotalMissed"
                android:text="12"
                android:textColor="#C62828"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Missed"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#E0E0E0"/>

        <!-- Total -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTotalDays"
                android:text="54"
                android:textColor="#1976D2"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Total"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>