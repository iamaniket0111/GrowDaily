<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:orientation="vertical"
    android:background="@drawable/circular_corners_more"
    android:layout_gravity="center"
    android:elevation="8dp">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Task Detected"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_gravity="center"
        android:drawablePadding="8dp"
        android:paddingBottom="12dp"
        app:drawableStartCompat="@drawable/ic_info"
        android:drawableTint="@color/category_dark_blue"
        />

    <TextView
        android:id="@+id/dialogMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your selection contains daily tasks. Please choose one of the options below:"
        android:textSize="14sp"
        android:textColor="#8A8A8A"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="24dp" />
    <!-- Options -->
    <RadioGroup
        android:id="@+id/radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <RadioButton
            android:id="@+id/radio_disable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No need to use further"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radio_remove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove completely" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/category_dark_blue"
        />
</LinearLayout>
