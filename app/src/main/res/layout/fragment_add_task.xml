<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/buttonSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/imageProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="6dp"
                    android:background="@drawable/circular"
                    android:contentDescription="@string/none"
                    android:padding="16dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_trophy"
                    app:tint="@color/white" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/circular"
                    android:backgroundTint="#77FFEB3B"
                    android:contentDescription="@string/none"
                    android:padding="4dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/category_green" />
            </FrameLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/isDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="16dp"
                android:checked="true"
                android:text="Repeat Daily"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Select Task Type"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioDailyTask"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Daily Task" />

                <RadioButton
                    android:id="@+id/radioDayTask"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today Task" />

                <RadioButton
                    android:id="@+id/radioUntilComplete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Until Complete" />

            </RadioGroup>

            <!-- Title -->
            <EditText
                android:id="@+id/editTextTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Title"
                android:inputType="textCapSentences"
                android:maxLines="1" />

            <!-- Note -->
            <EditText
                android:id="@+id/editTextNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Note (Optional)"
                android:inputType="textMultiLine"
                android:minLines="2" />


            <!-- Score Weight -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Select Task Weight"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioVeryLow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Very Low (1 wight)" />

                <RadioButton
                    android:id="@+id/radioLow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low (2 weight)" />

                <RadioButton
                    android:id="@+id/radioHigh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High (3 weight)" />

                <RadioButton
                    android:id="@+id/radioVeryHigh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Very High (4 weight)" />
            </RadioGroup>

            <!-- Condition view -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Select condition in which you are not being able to perform daily task"
                android:textAlignment="center"
                android:textStyle="bold" />

            <!-- Scheduled Time, date -->


            <!-- Reminder Switch -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCheckCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="16dp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/timeWorkContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSchedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Schedule" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchReminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Reminder" />


                </LinearLayout>

                <TextView
                    android:id="@+id/dummyTxtTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="@string/time"
                    android:textSize="18sp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/timeWorkContainer"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/circular_corners_more"
                    android:backgroundTint="@color/white"
                    android:padding="8dp"
                    android:text="--"
                    android:textAlignment="center"
                    android:textColor="@color/brand_blue"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/dummyTxtTime"
                    app:layout_constraintEnd_toEndOf="@id/dummyTxtTime"
                    app:layout_constraintStart_toStartOf="@id/dummyTxtTime"
                    app:layout_constraintTop_toTopOf="@id/dummyTxtTime" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Save Button -->

        </LinearLayout>
    </ScrollView>
    <!-- Add this inside your root layout, e.g., after buttonSave -->
    <ProgressBar
        android:id="@+id/progressBarSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:indeterminateTint="@color/brand_blue"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/buttonSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:backgroundTint="@color/brand_blue"
        android:text="Save Task"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>


