<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/buttonSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/imageProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="6dp"
                    android:background="@drawable/circular"
                    android:contentDescription="@string/none"
                    android:padding="16dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_trophy"
                    app:tint="@color/white" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/circular"
                    android:backgroundTint="@color/add_form_muted_surface"
                    android:contentDescription="@string/none"
                    android:padding="4dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/category_green" />
            </FrameLayout>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="32dp" />

            <!-- Title & Note (Variable Height) -->
            <include
                android:id="@+id/titleNoteLayout"
                layout="@layout/add_task_title_note_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/tvVersioningHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/add_task_info_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/circular"
                    android:backgroundTint="@color/task_filter_selected_bg"
                    android:padding="6dp"
                    android:src="@drawable/ic_warning"
                    app:tint="@color/brand_blue" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Changes apply going forward"
                        android:textColor="@color/add_form_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:lineSpacingExtra="1dp"
                        android:text="Priority, tracking, and repeat changes apply from today onward only. Past progress stays unchanged."
                        android:textColor="@color/add_form_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Priority (Fixed 56dp) -->
            <include
                android:id="@+id/taskWeightPriorityLayout"
                layout="@layout/task_weight_priority_layout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp" />

            <!-- Tracking Type (Variable Height) -->
            <include
                android:id="@+id/taskTrackingType"
                layout="@layout/layout_tracking_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Add to List (Fixed 56dp) -->
            <include
                android:id="@+id/addToListLayout"
                layout="@layout/task_add_to_list_layout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp" />

            <!-- Start Date (Fixed 56dp) -->
            <include
                android:id="@+id/startDateLayout"
                layout="@layout/task_start_date_layout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp" />

            <!-- Until Complete (Variable Height) -->
            <include
                android:id="@+id/untilCompleteLayout"
                layout="@layout/layout_day_until_complete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Repeat (Fixed 56dp) -->
            <include
                android:id="@+id/repeatLayout"
                layout="@layout/task_repeat_layout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp" />

            <!-- Schedule (Variable Height) -->
            <include
                android:id="@+id/scheduleLayout"
                layout="@layout/layout_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Reminder (Variable Height) -->
            <include
                android:id="@+id/reminderLayoutMain"
                layout="@layout/layout_reminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Delete/Pause (Fixed 56dp) -->
            <include
                android:id="@+id/deletePauseLayout"
                layout="@layout/layout_delete_pause"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBarSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:indeterminateTint="@color/brand_blue"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/navigationLoadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/task_screen_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="@color/brand_blue" />

        <TextView
            android:id="@+id/tvNavigationLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Going back..."
            android:textColor="@color/task_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:backgroundTint="@color/brand_blue"
        android:text="Save Task"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
