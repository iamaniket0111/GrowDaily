<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/shContainer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"

        android:orientation="vertical">

        <ImageView
            android:id="@+id/shView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Custom circle"
            android:gravity="center"
            android:paddingVertical="4dp"
            android:src="@drawable/sh_view3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <Space
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shDivider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="@color/task_timeline_line"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/shView" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/timeTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            android:text="08:00 AM"
            android:textColor="@color/task_text_secondary" />

        <LinearLayout
            android:id="@+id/body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:background="@drawable/task_fragment_card"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginVertical="16dp">

                <ImageView
                    android:id="@+id/imageProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circular"
                    android:contentDescription="@string/none"
                    android:padding="6dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/white" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    >
                    <TextView
                        android:id="@+id/taskType"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Daily"
                        android:textSize="14sp"
                        android:textColor="@color/brand_blue" />

                    <LinearLayout
                        android:id="@+id/weightContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/circular_corners_less"
                        android:backgroundTint="@color/brand_blue"

                        android:gravity="center"

                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp">

                        <TextView
                            android:id="@+id/taskWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1/4"
                            android:textColor="@color/default_text_color"
                            android:textSize="12sp" />

                        <ImageView
                            android:id="@+id/flag"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_flag_fill"
                            app:tint="@color/white" />
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/streakContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/circular_corners_less"
                        android:backgroundTint="@color/task_done_track"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp">

                        <TextView
                            android:id="@+id/taskStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/task_text_secondary"
                            android:textSize="12sp" />

                        <ImageView
                            android:id="@+id/fire"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_fire_fill"
                            app:tint="@color/iconTint" />
                    </LinearLayout>





                </LinearLayout>

                <TextView
                    android:id="@+id/taskTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:minLines="1"
                    android:text="Start the Day"
                    android:textColor="@color/task_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/taskNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="5"
                    android:textColor="@color/task_text_secondary"
                    android:text="be ready for the day" />

                <TextView
                    android:id="@+id/taskPendingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pending from Mar 28"
                    android:textColor="@color/brand_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/doneContainer"
                android:layout_width="38dp"
                android:layout_height="38dp"
                >
                <!-- fixme have to ada full stroke thickness .5-->


                <!-- Progress Arc -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/doneView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    app:indicatorSize="28dp"
                    app:trackThickness="2dp"
                    app:indicatorColor="@color/brand_blue"
                    app:trackColor="@color/task_done_track"
                    android:layout_gravity="center"
                    />



                <!-- Center Icon -->
                <ImageView
                    android:id="@+id/done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_check"
                    android:layout_gravity="center"
                    app:tint="@color/white"
                    android:background="@drawable/circular"
                    />

            </FrameLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
