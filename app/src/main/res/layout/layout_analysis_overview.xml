<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutOverview"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/circular_corners"
    android:padding="20dp">

    <!-- Section Title -->
    <TextView
        android:id="@+id/txtOverviewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACTIVITY OVERVIEW"
        android:textColor="@color/black"
        android:textSize="12sp"
        android:textStyle="normal"
        android:letterSpacing="0.05"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Stats Grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutStatsGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtOverviewTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Current Streak -->
        <LinearLayout
            android:id="@+id/layoutCurrentStreak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/divider1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txtCurrentStreakValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="#212121"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current streak"
                android:textColor="#9E9E9E"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/txtCurrentStreakDays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="days"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <!-- Divider 1 -->
        <View
            android:id="@+id/divider1"
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toEndOf="@id/layoutCurrentStreak"
            app:layout_constraintEnd_toStartOf="@id/layoutBestStreak"
            app:layout_constraintTop_toTopOf="@id/layoutCurrentStreak"
            app:layout_constraintBottom_toBottomOf="@id/layoutCurrentStreak" />

        <!-- Best Streak -->
        <LinearLayout
            android:id="@+id/layoutBestStreak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/divider1"
            app:layout_constraintEnd_toStartOf="@id/divider2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txtBestStreakValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14"
                android:textColor="#212121"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Best streak"
                android:textColor="#9E9E9E"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/txtBestStreakDays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="days"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <!-- Divider 2 -->
        <View
            android:id="@+id/divider2"
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toEndOf="@id/layoutBestStreak"
            app:layout_constraintEnd_toStartOf="@id/layoutDates"
            app:layout_constraintTop_toTopOf="@id/layoutCurrentStreak"
            app:layout_constraintBottom_toBottomOf="@id/layoutCurrentStreak" />

        <!-- Dates Section -->
        <LinearLayout
            android:id="@+id/layoutDates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/divider2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txtLastCompletedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mar 4, 2026"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                     />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last completed"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtLastMissedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feb 28, 2026"
                    android:textColor="#C62828"
                    android:textSize="14sp"
                     />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last missed"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.constraintlayout.widget.ConstraintLayout>