<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutOverview"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/circular_corners"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/txtOverviewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overview"
        android:textColor="#111111"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Current streak -->
    <LinearLayout
        android:id="@+id/layoutCurrentStreak"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtOverviewTitle"
        app:layout_constraintWidth_percent="0.33">

        <TextView
            android:id="@+id/txtCurrentStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 5"
            android:textColor="#FF6B35"
            android:textSize="22sp"
            android:layout_marginBottom="4dp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current streak"
            android:textColor="#777777"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/divider1"
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="@id/layoutCurrentStreak"
        app:layout_constraintStart_toEndOf="@id/layoutCurrentStreak"
        app:layout_constraintTop_toTopOf="@id/layoutCurrentStreak" />

    <!-- Completion -->
    <LinearLayout
        android:id="@+id/layoutCompletion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@id/divider2"
        app:layout_constraintStart_toEndOf="@id/divider1"
        app:layout_constraintTop_toTopOf="@id/layoutCurrentStreak"
        app:layout_constraintWidth_percent="0.34">

        <TextView
            android:id="@+id/txtCompletionPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:text="78%"
            android:textColor="#2196F3"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCompletionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="42 / 54 days"
            android:textColor="#777777"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/progressCompletion"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="78"
            android:progressBackgroundTint="#E0E0E0"
            android:progressTint="#2196F3" />
    </LinearLayout>


    <!-- Divider -->
    <View
        android:id="@+id/divider2"
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="@id/layoutCurrentStreak"
        app:layout_constraintStart_toEndOf="@id/layoutCompletion"
        app:layout_constraintTop_toTopOf="@id/layoutCurrentStreak" />

    <!-- Best streak -->
    <LinearLayout
        android:id="@+id/layoutBestStreak"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider2"
        app:layout_constraintTop_toTopOf="@id/layoutCurrentStreak"
        app:layout_constraintWidth_percent="0.33">

        <TextView
            android:id="@+id/txtBestStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 14"
            android:textColor="#FFC107"
            android:textSize="22sp"
            android:layout_marginBottom="4dp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Best streak"
            android:textColor="#777777"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
